# GEMINI_API_KEY: Optional, for AI Studio / Gemini API.
GEMINI_API_KEY="MY_GEMINI_API_KEY"
APP_URL="MY_APP_URL"

# Firebase (frontend). Use these in the client app for Firestore, Auth, Functions.
# API Key: Firebase Console > Project Settings > General > Your apps > Web API Key (não use "Restrict key" no início).
VITE_FIREBASE_API_KEY="your-api-key"
VITE_FIREBASE_AUTH_DOMAIN="agrorafia-bc484.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="agrorafia-bc484"
VITE_FIREBASE_STORAGE_BUCKET="agrorafia-bc484.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID="832451437369"
VITE_FIREBASE_APP_ID="1:832451437369:web:0f0579b541cb9455197ee8"
VITE_FIREBASE_MEASUREMENT_ID="G-XZR6JKXCED"

# Firebase Admin (backend only). For Cloud Functions locally, set GOOGLE_APPLICATION_CREDENTIALS
# to the path of agrorafia.json or use a service account key in CI (e.g. GitHub Secrets).
# Never expose agrorafia.json or private key in the frontend or in version control.
# GOOGLE_APPLICATION_CREDENTIALS=./agrorafia.json
